# LLM Comparator — demo mode environment variables
# Copy to .env for a demo deployment using DigitalOcean Serverless Inference.
# In demo mode, users supply their own API key via the UI; it is used only for
# inference calls and never persisted server-side.

# ----- Inference models (DigitalOcean Serverless Inference) -----
MODEL_1_ENDPOINT=https://inference.do-ai.run
MODEL_1_NAME=NemoTron 3 120B
MODEL_1_MODEL_ID=nvidia-nemotron-3-super-120b
MODEL_1_API_KEY=

MODEL_2_ENDPOINT=https://inference.do-ai.run
MODEL_2_NAME=GPT-OSS 120B
MODEL_2_MODEL_ID=openai-gpt-oss-120b
MODEL_2_API_KEY=

MODEL_3_ENDPOINT=https://inference.do-ai.run
MODEL_3_NAME=Llama 3 70B
MODEL_3_MODEL_ID=llama3.3-70b-instruct
MODEL_3_API_KEY=

# ----- Preference / scoring model -----
PREFERENCE_MODEL_ENDPOINT=https://inference.do-ai.run
PREFERENCE_MODEL_NAME=Claude 4.6 Sonnet
PREFERENCE_MODEL_MODEL_ID=anthropic-claude-4.6-sonnet
PREFERENCE_MODEL_API_KEY=

# ----- App settings -----
DATABASE_URL=sqlite+aiosqlite:///./llm_comparator.db

# ----- Demo mode -----
DEMO_MODE=true
# How long (hours) to keep demo runs before the background task purges them.
DEMO_SESSION_TTL_HOURS=24
