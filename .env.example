# LLM Comparator — environment variables
# Copy to .env and fill in your values.
# See .env.demo.example for a demo-mode configuration using DigitalOcean Serverless Inference.

# ----- Inference models (OpenAI-compatible endpoints) -----
# Endpoints can be local (e.g. Ollama), serverless (e.g. DigitalOcean Serverless Inference
# at https://inference.do-ai.run), or dedicated hosted endpoints.
MODEL_1_ENDPOINT=https://inference.do-ai.run
MODEL_1_NAME=NemoTron 3 120B
MODEL_1_API_KEY=
MODEL_1_MODEL_ID=nvidia-nemotron-3-super-120b
# MODEL_1_MODEL_ID=  # Optional: API model identifier sent as "model" in the request payload.
#                    # If unset, MODEL_1_NAME is used instead.
#                    # Required for most hosted APIs (e.g. DigitalOcean inference).

MODEL_2_ENDPOINT=http://localhost:11434
MODEL_2_NAME=GPT-OSS 120B
MODEL_2_API_KEY=
# MODEL_2_MODEL_ID=

MODEL_3_ENDPOINT=http://localhost:11434
MODEL_3_NAME=Llama 3
MODEL_3_API_KEY=
# MODEL_3_MODEL_ID=

# ----- Preference / scoring model -----
# Any OpenAI-compatible model. Larger, instruction-following models work best.
PREFERENCE_MODEL_ENDPOINT=https://inference.do-ai.run
PREFERENCE_MODEL_NAME=Claude 4.6 Sonnet
PREFERENCE_MODEL_API_KEY=
PREFERENCE_MODEL_MODEL_ID=anthropic-claude-4.6-sonnet

# ----- App settings -----
DATABASE_URL=sqlite+aiosqlite:///./llm_comparator.db
# Needed only for local dev (Vite runs on a separate port from the API).
# Leave unset in production — the built frontend is served same-origin.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
